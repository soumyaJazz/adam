<title>Skeleton #1 - Account Header</title>
<style>
  * { box-sizing: border-box; margin: 0; padding: 0; }

body {
font-family: ‘Segoe UI’, sans-serif;
background: #efefef;
padding: 24px 16px;
min-height: 100vh;
}

/* ── shimmer ── */
@keyframes shimmer {
0%   { background-position: -600px 0; }
100% { background-position:  600px 0; }
}
.bone {
background: linear-gradient(90deg, #e4e4e4 25%, #f5f5f5 50%, #e4e4e4 75%);
background-size: 600px 100%;
animation: shimmer 1.5s infinite linear;
border-radius: 3px;
display: inline-block;
}

/* ── card ── */
.card {
background: #fff;
border: 1px solid #ddd;
border-radius: 6px;
overflow: hidden;
}

/* breadcrumb row */
.breadcrumb {
padding: 9px 16px;
border-bottom: 1px solid #f0f0f0;
display: flex;
align-items: center;
gap: 8px;
}
.sep { color: #ccc; font-size: 12px; }

/* main row */
.main-row {
padding: 14px 16px;
display: flex;
align-items: center;
justify-content: space-between;
gap: 12px;
flex-wrap: wrap;
}

.left { display: flex; flex-direction: column; gap: 10px; }

.title-row {
display: flex;
align-items: center;
gap: 10px;
flex-wrap: wrap;
}

.red-bar {
width: 3px;
height: 22px;
background: #DB0011;
border-radius: 2px;
flex-shrink: 0;
}

.icons { display: flex; gap: 6px; margin-left: 6px; }

.search-ghost {
display: flex;
align-items: center;
gap: 8px;
border: 1px solid #e4e4e4;
border-radius: 4px;
padding: 7px 12px;
min-width: 130px;
flex-shrink: 0;
}

/* ── toggle button ── */
.controls {
display: flex;
align-items: center;
gap: 10px;
margin-bottom: 18px;
flex-wrap: wrap;
}

.label {
background: #1a1a1a;
color: #fff;
font-size: 10px;
font-weight: 700;
letter-spacing: 1px;
padding: 3px 8px;
border-radius: 3px;
text-transform: uppercase;
}

.btn {
padding: 6px 16px;
border: none;
border-radius: 4px;
background: #DB0011;
color: #fff;
font-size: 13px;
font-weight: 600;
cursor: pointer;
}
.btn.loaded { background: #2e7d32; }

/* ── real header (shown after load) ── */
.real-card {
background: #fff;
border: 1px solid #ddd;
border-radius: 6px;
overflow: hidden;
display: none;
}
.real-breadcrumb {
padding: 9px 16px;
border-bottom: 1px solid #f0f0f0;
font-size: 12px;
color: #666;
}
.real-main {
padding: 14px 16px;
display: flex;
align-items: center;
justify-content: space-between;
gap: 12px;
flex-wrap: wrap;
}
.real-title {
display: flex;
align-items: center;
gap: 10px;
flex-wrap: wrap;
}
.real-name { font-weight: 600; font-size: 14px; color: #111; }
.real-subtitle { font-size: 12px; color: #DB0011; text-decoration: underline; margin-left: 13px; margin-top: 5px; }
.real-search {
display: flex;
align-items: center;
gap: 6px;
border: 1px solid #e4e4e4;
border-radius: 4px;
padding: 7px 12px;
min-width: 120px;
font-size: 13px;
color: #aaa;
flex-shrink: 0;
}
</style>

</head>

      <div class="s-td"><div class="bone" style="width:50%;height:10px;"></div></div>
    </div>
    <!-- Row group 2 -->
    <div class="s-row grouped" style="margin-top:2px;">
      <div class="s-td"><div class="bone" style="width:22px;height:14px;border-radius:2px;"></div></div>
      <div class="s-td"><div class="bone" style="width:85%;height:10px;"></div></div>

    </div>
    <div class="s-row">
      <div class="s-td"></div>
      <div class="s-td"><div class="bone" style="width:70%;height:10px;"></div></div>
      <div class="s-td"><div class="bone" style="width:90%;height:10px;"></div></div>
      <div class="s-td"><div class="bone" style="width:80%;height:10px;"></div></div>

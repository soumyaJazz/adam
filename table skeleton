    </div>
    <div class="s-row">
      <div class="s-td"></div>
      <div class="s-td"><div class="bone" style="width:60%;height:10px;"></div></div>
      <div class="s-td"><div class="bone" style="width:85%;height:10px;"></div></div>
      <div class="s-td"><div class="bone" style="width:75%;height:10px;"></div></div>

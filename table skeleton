<!DOCTYPE html>

<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>Skeleton - Table</title>
<style>
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body { font-family: 'Segoe UI', sans-serif; background: #efefef; padding: 20px 16px; min-height: 100vh; }

@keyframes shimmer {
0%   { background-position: -600px 0; }
100% { background-position:  600px 0; }
}
.bone {
background: linear-gradient(90deg, #e4e4e4 25%, #f5f5f5 50%, #e4e4e4 75%);
background-size: 600px 100%;
animation: shimmer 1.5s infinite linear;
border-radius: 3px;
display: block;
}

.controls { display: flex; align-items: center; gap: 10px; margin-bottom: 18px; flex-wrap: wrap; }
.label { background: #1a1a1a; color: #fff; font-size: 10px; font-weight: 700; letter-spacing: 1px; padding: 3px 8px; border-radius: 3px; text-transform: uppercase; }
.btn { padding: 6px 16px; border: none; border-radius: 4px; background: #DB0011; color: #fff; font-size: 13px; font-weight: 600; cursor: pointer; }
.btn.loaded { background: #2e7d32; }

/* shared layout */
.card { background: #fff; border: 1px solid #ddd; border-radius: 6px; overflow: hidden; display: flex; min-height: 300px; }
.left-panel { width: 130px; flex-shrink: 0; border-right: 1px solid #f0f0f0; padding: 12px 10px; display: flex; flex-direction: column; gap: 12px; }
.right-panel { flex: 1; display: flex; flex-direction: column; overflow: hidden; }

/* skeleton rows */
.s-summary { padding: 10px 12px; border-bottom: 1px solid #f0f0f0; display: flex; gap: 20px; }
.s-sum-item { display: flex; flex-direction: column; gap: 5px; }
.s-thead { display: flex; padding: 8px 12px; border-bottom: 2px solid #f0f0f0; background: #fafafa; gap: 4px; }
.s-th { flex: 1; }
.s-row { display: flex; align-items: center; padding: 10px 12px; border-bottom: 1px solid #f8f8f8; gap: 4px; }
.s-row.grouped { border-left: 3px solid #DB0011; background: #fff8f8; }
.s-td { flex: 1; }

/* mid id item */
.mid-block { display: flex; flex-direction: column; gap: 6px; padding-bottom: 10px; border-bottom: 1px solid #f5f5f5; }
.mid-block:last-child { border-bottom: none; }
.mid-top-row { display: flex; align-items: center; gap: 5px; }

/* real content */
.real-card { background: #fff; border: 1px solid #ddd; border-radius: 6px; overflow: hidden; display: none; flex-direction: row; min-height: 300px; font-size: 11px; }
.r-left { width: 130px; flex-shrink: 0; border-right: 1px solid #f0f0f0; padding: 12px 10px; display: flex; flex-direction: column; gap: 10px; }
.r-mid { display: flex; flex-direction: column; gap: 4px; padding-bottom: 10px; border-bottom: 1px solid #f0f0f0; }
.r-mid:last-child { border-bottom: none; }
.r-mid-id { color: #1a6fb5; font-size: 11px; font-weight: 600; }
.r-mid-sub { font-size: 10px; color: #888; }
.r-right { flex: 1; display: flex; flex-direction: column; }
.r-summary { display: flex; gap: 18px; padding: 10px 12px; border-bottom: 1px solid #f0f0f0; background: #fafafa; flex-wrap: wrap; }
.r-s-val { font-size: 14px; font-weight: 700; color: #111; }
.r-s-lbl { font-size: 9px; color: #888; text-transform: uppercase; letter-spacing: 0.4px; margin-top: 2px; }
.r-thead { display: flex; padding: 7px 12px; border-bottom: 2px solid #e8e8e8; background: #f5f5f5; font-size: 9px; font-weight: 700; color: #666; text-transform: uppercase; letter-spacing: 0.4px; }
.r-th { flex: 1; padding-right: 4px; }
.r-row { display: flex; align-items: center; padding: 9px 12px; border-bottom: 1px solid #f5f5f5; }
.r-row.grouped { background: #fff8f8; border-left: 3px solid #DB0011; }
.r-td { flex: 1; padding-right: 4px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; font-size: 10px; color: #333; }
.pill { font-size: 9px; font-weight: 700; color: #fff; padding: 2px 5px; border-radius: 2px; display: inline-block; }
.lcr { background: #1a6fb5; }
.scr { background: #2e7d32; }
.r-title { font-size: 11px; font-weight: 700; color: #111; margin-bottom: 4px; }
</style>

</head>
<body>

<div class="controls">
  <span class="label">Skeleton — Transactions Table</span>
  <button class="btn" id="toggleBtn" onclick="toggle()">Simulate Load ✓</button>
</div>

